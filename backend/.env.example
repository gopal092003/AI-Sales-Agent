# =========================================================
# APP CONFIGURATION
# =========================================================

APP_NAME=AI Sales Intelligence Agent
APP_ENV=development
DEBUG=True

API_V1_PREFIX=/api

# =========================================================
# SERVER
# =========================================================

HOST=0.0.0.0
PORT=8000

# =========================================================
# DATABASE
# =========================================================

DATABASE_URL=sqlite:///./sales_agent.db

# =========================================================
# AI PROVIDERS
# =========================================================

# Groq API
GROQ_API_KEY=your_groq_api_key

# Default model
DEFAULT_LLM_MODEL=llama3-70b-8192

# =========================================================
# OLLAMA
# =========================================================

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# =========================================================
# SCRAPING
# =========================================================

REQUEST_TIMEOUT=30
MAX_RETRIES=3

USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# =========================================================
# CORS
# =========================================================

BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =========================================================
# LOGGING
# =========================================================

LOG_LEVEL=INFO

# =========================================================
# OPTIONAL FEATURES
# =========================================================

ENABLE_NEWS_SCRAPING=True
ENABLE_TECHSTACK_DETECTION=True
ENABLE_HIRING_SIGNALS=True

# =========================================================
# FUTURE INTEGRATIONS
# =========================================================

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# SERPAPI_API_KEY=
# RESEND_API_KEY=
# REDIS_URL=